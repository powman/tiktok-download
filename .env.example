# Backend Configuration
FLASK_ENV=production
FLASK_APP=app.py
PYTHONUNBUFFERED=1

# API Settings
API_HOST=0.0.0.0
API_PORT=5000

# Video Processing
WORK_DIR=/downloads
FFMPEG_PATH=/usr/bin/ffmpeg

# YoutubeDL Settings
YTDLP_FORMAT=best[format_id*=video]/best
YTDLP_OUTPUT=/downloads/%(title)s.%(ext)s

# CORS
CORS_ORIGINS=http://localhost:8080

# Frontend API Configuration
VITE_API_URL=http://localhost:5001
VITE_EXTRACT_API_URL=http://localhost:5001
