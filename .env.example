# Backend Configuration
FLASK_ENV=production
FLASK_APP=app.py
PYTHONUNBUFFERED=1

# API Settings
API_HOST=0.0.0.0
API_PORT=5000

# Video Processing
WORK_DIR=/downloads
FFMPEG_PATH=/usr/bin/ffmpeg

# YoutubeDL Settings
YTDLP_FORMAT=best[format_id*=video]/best
YTDLP_OUTPUT=/downloads/%(title)s.%(ext)s

# CORS
CORS_ORIGINS=http://localhost:8080

# Public URL used to build links to processed videos
# In production, set to your server's public domain/IP, e.g. http://93.127.212.198:5001
PUBLIC_BASE_URL=http://localhost:5001

# Frontend API Configuration
# In production, set to your server's public domain/IP, e.g. http://93.127.212.198:5001
VITE_API_URL=http://localhost:5001

# Google Sheets (histórico de envios)
GOOGLE_SHEETS_ID=1Z9FeeD9m6ioPWTIMTLzwhAqj4R7i8-6juQ9N-KAWbd0
